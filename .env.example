# ============================================================================
# BACKEND — Variables serveur (Railway / Render / Fly.io)
# ============================================================================

# Database (TiDB Cloud)
DATABASE_URL=mysql://user:password@host:4000/database?ssl={"rejectUnauthorized":true}

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Manus OAuth
OAUTH_SERVER_URL=https://...
VITE_APP_ID=your-app-id
JWT_SECRET=your-jwt-secret
OWNER_OPEN_ID=your-owner-open-id

# Manus Forge API (for storage, LLM, etc.)
BUILT_IN_FORGE_API_URL=https://...
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Frontend URL (for CORS + OAuth redirect)
FRONTEND_URL=https://your-app.vercel.app

# Server port
PORT=3000

# ============================================================================
# FRONTEND — Variables Vercel (préfixées VITE_)
# ============================================================================

# Backend API URL (set in Vercel dashboard)
# VITE_API_URL=https://your-backend.railway.app

# Stripe publishable key (public, safe for frontend)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Manus OAuth
# VITE_OAUTH_PORTAL_URL=https://...
# VITE_APP_ID=your-app-id
